{
  "expo": {
    "name": "frontend-app",
    "slug": "frontend-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to support wellbeing and safety features.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to support wellbeing and safety features, even when the app is closed.",
        "UIBackgroundModes": ["location"],
        "NSMicrophoneUsageDescription": "This app uses microphone access to measure ambient sound levels for wellbeing features."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ankyv.frontendapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-font",
      "./plugins/withNotifeeMavenRepo",
      "expo-audio",
      "expo-asset"
    ]
  }
}
